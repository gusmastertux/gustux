
{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/ticket", "dest": "/api/ticket.js" },
    { "src": "/api/appointment", "dest": "/api/appointment.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
